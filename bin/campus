#!/usr/bin/env bash
# One command to connect any project -- any language -- to the campus, from anywhere.
#
#   campus install [path]     add campus hooks to a project (default: current dir)
#   campus uninstall [path]   remove them
#   campus team [path]        scaffold an optional team roster (.claude/campus.json)
#   campus link               put this `campus` command on your PATH (one time)
#
# It never touches anything but the target's .claude/ directory, and it needs no pnpm,
# no cd into the campus repo, and no Node.js in the project being connected.
set -euo pipefail

# Resolve this script's real location even when run through a PATH symlink, so we can
# always find the campus repo it lives in.
src="${BASH_SOURCE[0]}"
while [ -h "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  src="$(readlink "$src")"
  case "$src" in /*) ;; *) src="$dir/$src" ;; esac
done
BIN_DIR="$(cd -P "$(dirname "$src")" && pwd)"
REPO_ROOT="$(cd -P "$BIN_DIR/.." && pwd)"
TSX="$REPO_ROOT/node_modules/.bin/tsx"

usage() { sed -n '2,10p' "$src" | sed 's/^# \{0,1\}//'; }

run() { # <script> <args...>
  if [ ! -x "$TSX" ]; then
    echo "campus: missing $TSX -- run 'pnpm install' in $REPO_ROOT first." >&2
    exit 1
  fi
  exec "$TSX" "$1" "${@:2}"
}

do_link() {
  local self="$BIN_DIR/campus" dest=""
  for d in "$HOME/.local/bin" "/usr/local/bin" "/opt/homebrew/bin"; do
    if [ -d "$d" ] && [ -w "$d" ]; then dest="$d"; break; fi
  done
  if [ -z "$dest" ]; then dest="$HOME/.local/bin"; mkdir -p "$dest"; fi
  ln -sf "$self" "$dest/campus"
  echo "campus: linked $dest/campus -> $self"
  case ":$PATH:" in
    *":$dest:"*) echo "campus: ready. Run 'campus install' inside any project." ;;
    *) echo "campus: add it to your PATH:  export PATH=\"$dest:\$PATH\"" ;;
  esac
}

cmd="${1:-help}"
[ "$#" -gt 0 ] && shift || true
case "$cmd" in
  install)   run "$REPO_ROOT/packages/claude-plugin/installer/install.ts" "$@" ;;
  uninstall) run "$REPO_ROOT/packages/claude-plugin/installer/uninstall.ts" "$@" ;;
  team)      run "$REPO_ROOT/scripts/campus-team.ts" "$@" ;;
  link)      do_link ;;
  help|-h|--help) usage ;;
  *) echo "campus: unknown command '$cmd'" >&2; usage; exit 1 ;;
esac
